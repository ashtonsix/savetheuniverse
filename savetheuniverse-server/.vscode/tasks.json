{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build",
			"type": "shell",
			"command": "${workspaceFolder}/scripts/build.sh",
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "Run",
			"type": "shell",
			"command": "${workspaceFolder}/scripts/run.sh",
			"group": "test",
			"dependsOn": ["Build"]
		}
	]
}
